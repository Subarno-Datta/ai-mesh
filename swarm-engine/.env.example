# Aura-Mesh Swarm Engine Configuration
# Copy this file to .env and fill in your values

TARGET_API_URL=http://localhost:4000
TARGET_API_PORT=4000
WS_HOST=0.0.0.0
WS_PORT=8765
LOG_POLL_INTERVAL=0.5
CONTEXT_LINES=50
MAX_PATCH_RETRIES=3

# ============================================
# LLM Provider Selection
# ============================================
# Options: "ollama" | "huggingface" | "openai"
LLM_PROVIDER=ollama

# --- Option 1: Ollama (local, default) ---
# Run: ollama serve && ollama pull <model>
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4e2b-forced:latest

# --- Option 2: Hugging Face Inference API ---
# Free tier available! Get token: https://huggingface.co/settings/tokens
# AMD partnership: optimized for ROCm/ONNX on HF Hub
#
# Recommended code models:
#   Qwen/Qwen2.5-Coder-32B-Instruct  (best for code, free on HF Inference)
#   google/gemma-2-9b-it              (solid general + code)
#   mistralai/Mistral-7B-Instruct-v0.3
#   bigcode/starcoder2-15b-instruct-v0.1
#
HF_API_TOKEN=your_hf_token_here
HF_MODEL_ID=Qwen/Qwen2.5-Coder-32B-Instruct

# --- Option 3: OpenAI-Compatible API ---
# Works with ANY OpenAI-compatible endpoint:
#   OpenAI:     https://api.openai.com/v1
#   Groq:       https://api.groq.com/openai/v1
#   Together:   https://api.together.xyz/v1
#   OpenRouter: https://openrouter.ai/api/v1
#   Fireworks:  https://api.fireworks.ai/inference/v1
#   Local:      http://localhost:8080/v1  (llama.cpp, vLLM, etc.)
#
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
